#, elixir-autogen, elixir-format
msgid "Ease access for participants"
msgstr "Einfacher Zugang für die Teilnehmer"

#: lib/admin_web/controllers/landing_html/index.html.heex:156
#, elixir-autogen, elixir-format
msgid "Easily share with your class and collegues"
msgstr "Teilen Sie es ganz einfach mit Ihrer Klasse und Ihren Kollegen."

