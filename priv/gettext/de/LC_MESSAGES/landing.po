#: lib/admin_web/controllers/landing_html/about.html.heex:22
#, elixir-autogen, elixir-format
msgid "Founded by a dedicated team of professionals, our mission is to bridge the gap between cutting-edge technology and education, empowering educators and researchers globally."
msgstr "Gegründet von einem engagierten Team von Fachleuten, ist es unsere Mission, die Kluft zwischen Spitzentechnologie und Bildung zu überbrücken und Pädagogen und Forscher weltweit zu unterstützen."

#: lib/admin_web/controllers/landing_html/index.html.heex:40
#, elixir-autogen, elixir-format
msgid "Get started"
msgstr "Los geht's!"

#: lib/admin_web/controllers/landing_html/index.html.heex:221
#, elixir-autogen, elixir-format
msgid "Go to Graasp Library"
msgstr "Gehe zur Graasp-Bibliothek"

